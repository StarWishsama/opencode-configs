{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "jetbrain-idea": {
      "type": "local",
      "environment": {
        "IJ_MCP_SERVER_PORT": "USE JETBRAINS IDEA PROVIDED SERVER PORT",
      },
      "command": [
        "USE JETBRAINS IDEA PROVIDED STARTUP COMMAND"
      ],
      "enabled": true,
    },
    "mysql-mcp-server": {
      "type": "local",
      // For more details check https://github.com/benborla/mcp-server-mysql
      "environment": {
        "MYSQL_HOST": "localhost",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "",
        "MYSQL_PASS": "",
        "MYSQL_DB": "",
        "ALLOW_INSERT_OPERATIONS": "false",
        "ALLOW_UPDATE_OPERATIONS": "false",
        "ALLOW_DELETE_OPERATIONS": "false",
        "MYSQL_ENABLE_LOGGING": "true",
        "MULTI_DB_WRITE_MODE": "false",
      },
      "command": ["mcp-server-mysql"],
      "enabled": true,
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": {}
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git add *": "allow",
      "git log *": "allow",
      "git show *": "allow",
    },
    "jetbrain-idea_replace_text_in_file": "ask",
    "jetbrain-idea_rename_refactoring": "ask",
    "jetbrain-idea_execute_terminal_command": "ask",
    "jetbrain-idea_create_new_file": "ask",
  },
  "plugin": [
    "opencode-wakatime@latest",
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "@slkiser/opencode-quota",
  ],
}
