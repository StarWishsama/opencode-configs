{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "USE YOUR API KEY"
            },
            "enabled": true
        },
        "jetbrain-idea": {
            "type": "local",
            "environment": {
                "IJ_MCP_SERVER_PORT": "64342"
            },
            "command": [
                "USE JETBRAINS IDEA PROVIDED STARTUP COMMAND"
            ],
            "enabled": true
        },
        "mysql-mcp-server": {
            "type": "local",
            // For more details check https://github.com/benborla/mcp-server-mysql
            "environment": {
                "MYSQL_HOST": "127.0.0.1",
                "MYSQL_PORT": "3306",
                "MYSQL_USER": "root",
                "MYSQL_PASS": "",
                "MYSQL_DB": "",
                "ALLOW_INSERT_OPERATIONS": "false",
                "ALLOW_UPDATE_OPERATIONS": "false",
                "ALLOW_DELETE_OPERATIONS": "false",
                "MYSQL_ENABLE_LOGGING": "true",
                "MULTI_DB_WRITE_MODE": "false"
            },
            "command": [
                "npx -y @benborla29/mcp-server-mysql"
            ],
            "enabled": true
        }
    },
    "permission": {
        "edit": "ask",
        "bash": {
            "*": "ask",
            "git status": "allow",
            "git add *": "allow",
            "git log *": "allow",
            "git show *": "allow"
        },
        "jetbrain-idea_replace_text_in_file": "ask",
        "jetbrain-idea_rename_refactoring": "ask",
        "jetbrain-idea_execute_terminal_command": "ask"
    },
    "plugin": [
        "opencode-wakatime",
        "@tarquinen/opencode-dcp@latest",
        "@mohak34/opencode-notifier@latest",
        "@slkiser/opencode-quota@latest",
        "opencode-mem"
    ]
}