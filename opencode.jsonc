{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "USE YOUR CONTEXT7 KEY, recommend use context7 skill",
      },
      "enabled": true,
    },
    "jetbrain-idea": {
      "type": "remote",
      "url": "http://127.0.0.1:64342/sse", // Use idea provided url
      "headers": {},
      "enabled": true,
    },
    "dbx": {
      "type": "local",
      "command": ["npx", "-y", "@dbx-app/mcp-server"],
      "enabled": true,
      "env": {
        "DBX_MCP_ALLOW_WRITES": "0",
      },
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": {}
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "git status": "allow",
      "git add *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "rg *": "allow",
      "*": "ask"
    },
    "jetbrain-idea_replace_text_in_file": "ask",
    "jetbrain-idea_rename_refactoring": "ask",
    "jetbrain-idea_execute_terminal_command": "ask",
    "jetbrain-idea_create_new_file": "ask"
  },
  "plugin": [
    "opencode-wakatime@latest",
    "@tarquinen/opencode-dcp@latest",
    "@mohak34/opencode-notifier@latest",
    "@slkiser/opencode-quota@latest",
    "cc-safety-net"
  ],
}
